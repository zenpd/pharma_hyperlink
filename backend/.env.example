# Hyperlink Engine — environment configuration template
#
# Copy to .env and adjust. All keys are optional; defaults in settings.py
# work for a local dev setup.

# ── Paths ───────────────────────────────────────────────────────────────
HYPERLINK_DATA_DIR=data
HYPERLINK_OUTPUT_DIR=output
HYPERLINK_AUDIT_LOG_PATH=audit.jsonl

# ── LLM (local-only; do NOT point at external APIs in production) ───────
HYPERLINK_OLLAMA_HOST=http://localhost:11434
# Local Ollama model tag. Pull once: ollama pull llama3.2:3b
HYPERLINK_OLLAMA_MODEL=llama3.2:3b
HYPERLINK_LLM_TEMPERATURE=0.0
HYPERLINK_LLM_CONFIDENCE_THRESHOLD=0.7
# Send EVERY detected span to the LLM (not just low-confidence ones).
# Use with the Max-Accuracy profile to guarantee the LLM is exercised.
HYPERLINK_LLM_FORCE_REFINE=false

# ── LLM provider switch (POC) ───────────────────────────────────────────
# "ollama" = local daemon (default, GxP/on-prem path). "nvidia" = remote
# NVIDIA API Catalog (OpenAI-compatible) — sends prompts OFF-MACHINE, so
# POC / synthetic-data ONLY, never real dossiers.
HYPERLINK_LLM_PROVIDER=ollama
HYPERLINK_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
HYPERLINK_NVIDIA_MODEL=meta/llama-3.1-8b-instruct
# Cloud API key (only used when llm_provider=nvidia). Leave blank for local.
HYPERLINK_LLM_API_KEY=

# ── LangSmith tracing (DEV ONLY — must be local/self-hosted; see docs/langsmith-dev.md) ──
HYPERLINK_LANGSMITH_TRACING=false
HYPERLINK_LANGSMITH_ENDPOINT=http://localhost:1984
HYPERLINK_LANGSMITH_PROJECT=hyperlink-engine
HYPERLINK_LANGSMITH_API_KEY=

# ── Embeddings ──────────────────────────────────────────────────────────
HYPERLINK_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Graph backend ───────────────────────────────────────────────────────
# Use "networkx" for Phase 1 (in-memory). Switch to "neo4j" for Phase 2+.
HYPERLINK_GRAPH_BACKEND=networkx
HYPERLINK_NEO4J_URI=bolt://localhost:7687
HYPERLINK_NEO4J_USER=neo4j
HYPERLINK_NEO4J_PASSWORD=changeme

# ── Pipeline ────────────────────────────────────────────────────────────
HYPERLINK_REDIS_URL=redis://localhost:6379/0
HYPERLINK_CELERY_CONCURRENCY=4

# ── Dossplorer integration (mocked in Phase 1) ──────────────────────────
HYPERLINK_DOSSPLORER_BASE_URL=http://localhost:8080/mock-dossplorer
HYPERLINK_DOSSPLORER_OAUTH_TOKEN=
HYPERLINK_DOSSPLORER_MOCK_MODE=true

# ── Validation thresholds ───────────────────────────────────────────────
HYPERLINK_DETECTION_MIN_CONFIDENCE=0.6
HYPERLINK_TARGET_SIMILARITY_THRESHOLD=0.75
HYPERLINK_BLUE_TEXT_RGB_TOLERANCE=40

# ── Logging ─────────────────────────────────────────────────────────────
HYPERLINK_LOG_LEVEL=INFO
HYPERLINK_LOG_FORMAT=json

# ── Compliance ──────────────────────────────────────────────────────────
# DO NOT change to false outside of explicitly approved dev experiments.
HYPERLINK_ENFORCE_LOCAL_LLM_ONLY=true

# ── Auth (PLAN SEVEN — SuperTokens self-hosted) ─────────────────────────
# Master switch for the auth + document-classification gate. Stays false
# (today's open behavior) until you enforce it. Also runtime-togglable by an
# admin via the Security button (POST /api/auth/mode).
HYPERLINK_AUTH_ENABLED=false
# SuperTokens core (runs in-VPC via docker-compose; never external).
HYPERLINK_SUPERTOKENS_CONNECTION_URI=http://localhost:3567
# Shared secret between the backend SDK and the core container (also set as
# API_KEYS on the supertokens-core service). Leave blank for local-only dev.
HYPERLINK_SUPERTOKENS_API_KEY=
# Session/cookie domains.
HYPERLINK_API_DOMAIN=http://localhost:8000
HYPERLINK_WEBSITE_DOMAIN=http://localhost:5174
HYPERLINK_SESSION_COOKIE_SECURE=false
# Default sensitivity for a new run when the uploader doesn't pick one:
# "classified" (deny-by-default, secure) | "unclassified" (open).
HYPERLINK_DEFAULT_CLASSIFICATION=classified

# ── SuperTokens core's Postgres (docker-compose env) ────────────────────
POSTGRES_USER=supertokens
POSTGRES_PASSWORD=changeme
POSTGRES_DB=supertokens
