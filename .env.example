# Hyperlink Engine — environment configuration template
#
# Copy to .env and adjust. All keys are optional; defaults in settings.py
# work for a local dev setup.

# ── Paths ───────────────────────────────────────────────────────────────
HYPERLINK_DATA_DIR=data
HYPERLINK_OUTPUT_DIR=output
HYPERLINK_AUDIT_LOG_PATH=audit.jsonl

# ── LLM (local-only; do NOT point at external APIs in production) ───────
HYPERLINK_OLLAMA_HOST=http://localhost:11434
HYPERLINK_OLLAMA_MODEL=llama3.1:8b
HYPERLINK_LLM_TEMPERATURE=0.0
HYPERLINK_LLM_CONFIDENCE_THRESHOLD=0.7

# ── Embeddings ──────────────────────────────────────────────────────────
HYPERLINK_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Graph backend ───────────────────────────────────────────────────────
# Use "networkx" for Phase 1 (in-memory). Switch to "neo4j" for Phase 2+.
HYPERLINK_GRAPH_BACKEND=networkx
HYPERLINK_NEO4J_URI=bolt://localhost:7687
HYPERLINK_NEO4J_USER=neo4j
HYPERLINK_NEO4J_PASSWORD=changeme

# ── Pipeline ────────────────────────────────────────────────────────────
HYPERLINK_REDIS_URL=redis://localhost:6379/0
HYPERLINK_CELERY_CONCURRENCY=4

# ── Dossplorer integration (mocked in Phase 1) ──────────────────────────
HYPERLINK_DOSSPLORER_BASE_URL=http://localhost:8080/mock-dossplorer
HYPERLINK_DOSSPLORER_OAUTH_TOKEN=
HYPERLINK_DOSSPLORER_MOCK_MODE=true

# ── Validation thresholds ───────────────────────────────────────────────
HYPERLINK_DETECTION_MIN_CONFIDENCE=0.6
HYPERLINK_TARGET_SIMILARITY_THRESHOLD=0.75
HYPERLINK_BLUE_TEXT_RGB_TOLERANCE=40

# ── Logging ─────────────────────────────────────────────────────────────
HYPERLINK_LOG_LEVEL=INFO
HYPERLINK_LOG_FORMAT=json

# ── Compliance ──────────────────────────────────────────────────────────
# DO NOT change to false outside of explicitly approved dev experiments.
HYPERLINK_ENFORCE_LOCAL_LLM_ONLY=true
